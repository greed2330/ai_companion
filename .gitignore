# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# HANA Project .gitignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── 개인 데이터 (절대 커밋 금지) ─────────────
data/
# 대화 DB, 벡터 DB, 일기, LoRA 어댑터 전부 포함
# 개인 대화 내용이 담겨 있음


# ── 모델 파일 (너무 큼) ───────────────────────
/models/
# HuggingFace 원본 safetensors 파일 (수십 GB)
*.safetensors
*.gguf
*.bin
*.pt
*.pth


# ── 환경 변수 & 시크릿 ───────────────────────
.env
.env.local
.env.*.local
backend/credentials/
# API 키, OAuth 토큰 등 민감 정보


# ── Python ───────────────────────────────────
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/


# ── Node.js ───────────────────────────────────
node_modules/
frontend/node_modules/
minecraft/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm


# ── Electron 빌드 산출물 ─────────────────────
dist/
frontend/dist/
frontend/build/
out/
release/


# ── IDE & 에디터 ──────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ── 로그 ─────────────────────────────────────
*.log
logs/
celery*.log


# ── Docker ───────────────────────────────────
# (docker-compose 파일은 커밋 대상)
.docker/


# ── 테스트 커버리지 ───────────────────────────
.coverage
coverage/
htmlcov/
.pytest_cache/


# ── 임시 파일 ─────────────────────────────────
*.tmp
*.temp
tmp/
temp/


# ── Whisper 캐시 ─────────────────────────────
~/.cache/whisper/
